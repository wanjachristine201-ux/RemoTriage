# ============================================================
# RemoTriage v4 — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── SERVER ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# NODE_ENV options: development | production | test

# ── DATABASE ─────────────────────────────────────────────────
# MongoDB connection string. Leave blank to run in triage-only mode (no DB).
MONGODB_URI=mongodb://localhost:27017/remotriage

# ── JWT AUTH ─────────────────────────────────────────────────
# Must be a long random secret. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── AI (ANTHROPIC) ───────────────────────────────────────────
# Get your key at https://console.anthropic.com
# If not set, the AI guidance layer will use offline fallback messages.
ANTHROPIC_API_KEY=sk-ant-...

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * for development only.
CORS_ORIGIN=http://localhost:5173

# ── RATE LIMITING ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── FACILITY SEARCH ──────────────────────────────────────────
# Radius in km for KMHFR geospatial facility queries
KMHFR_SEARCH_RADIUS_KM=25

# ── LOGGING ──────────────────────────────────────────────────
# Log level: error | warn | info | verbose | debug
LOG_LEVEL=info

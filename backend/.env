# ============================================================
# RemoTriage v4 — Environment Variables
# ============================================================

# ── SERVER ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── DATABASE ─────────────────────────────────────────────────
# MongoDB connection string. Leave blank to run in triage-only mode (no DB).
MONGODB_URI=mongodb://localhost:27017/remotriage

# ── JWT AUTH ─────────────────────────────────────────────────
JWT_SECRET=remotriage_development_secret_key_2025_secure_random_string_for_jwt_tokens
JWT_EXPIRES_IN=7d

# ── AI (ANTHROPIC) ───────────────────────────────────────────
# If not set, AI guidance layer will use offline fallback messages.
ANTHROPIC_API_KEY=sk-ant-api03-demo-key-placeholder

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── RATE LIMITING ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── FACILITY SEARCH ──────────────────────────────────────────
KMHFR_SEARCH_RADIUS_KM=25

# ── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=info
